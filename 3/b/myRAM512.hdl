// File name: projects/3/b/RAM512.hdl
/**
 * Memory of 512 16-bit registers.
 * If load is asserted, the value of the register selected by
 * address is set to in; Otherwise, the value does not change.
 * The value of the selected register is emitted by out.
 */
CHIP myRAM512 {
    IN in[16], load, address[9];
    OUT out[16];

    PARTS:
    myDMux8Way(in=load,sel=address[6..8],a=in1,b=in2,c=in3,d=in4,e=in5,f=in6,g=in7,h=in8);
    myRAM64(in=in,load=in1,address=address[0..5],out=out1);
myRAM64(in=in,load=in2,address=address[0..5],out=out2);
myRAM64(in=in,load=in3,address=address[0..5],out=out3);
myRAM64(in=in,load=in4,address=address[0..5],out=out4);
myRAM64(in=in,load=in5,address=address[0..5],out=out5);
myRAM64(in=in,load=in6,address=address[0..5],out=out6);
myRAM64(in=in,load=in7,address=address[0..5],out=out7);
myRAM64(in=in,load=in8,address=address[0..5],out=out8);
myMux8Way16(a=out1,b=out2,c=out3,d=out4,e=out5,f=out6,g=out7,h=out8,sel=address[6..8],out=out);
}
