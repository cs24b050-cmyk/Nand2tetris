// File name: projects/1/Or.hdl
/**
 * Or gate:
 * if (a or b) out = 1, else out = 0 
 */
CHIP myOr {
    IN a, b;
    OUT out;

    PARTS:
    //// Replace this comment with your code.
    myNot(in = a, out = out1);
    myNot(in = b, out = out2);
    Nand(a=out1,b=out2,out=out);
}
